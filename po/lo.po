#: common/resources/appearance-dialog.glade:68
msgid "Text next to icons"
msgstr "ຂໍ້ຄວາມຂ້າງໄອຄອນ"

#: common/resources/appearance-dialog.glade:82
msgid "1x (no scaling)"
