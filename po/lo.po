#. * we don't know the vendor. When a vendor is known, the name of the
#. * vendor is used.
#: ../common/display-name.c:2641
msgctxt "Monitor vendor"
msgid "Unknown"
msgstr "ບໍ່ຮູ້ຈັກ"

#: ../common/xfce-randr.c:299 ../dialogs/display-settings/main.c:4391
#, c-format
msgid "Unable to query the version of the RandR extension being used"
msgstr "ບໍ່ສາມາດກວດສອບເວີຊັນຂອງ RandR extension ທີ່ກຳລັງໃຊ້ງານຢູ່ໄດ້"

#. 1.2 is required
#: ../common/xfce-randr.c:307
#, c-format
msgid ""
"This system is using RandR %d.%d. For the display settings to work version "
"1.2 is required at least"
msgstr ""
"ລະບົບນີ້ກຳລັງໃຊ້ RandR %d.%d. ເພື່ອໃຫ້ການຕັ້ງຄ່າຈໍສະແດງຜົນເຮັດງານໄດ້ "
"ຕ້ອງມີເວີຊັນ 1.2 ເປັນຢ່າງຕ່ຳ"

#: ../common/xfce-randr.c:597
msgid "Laptop"
msgstr "ແລັບທັອບ"

#. TRANSLATORS: an externally connected display, where %s is either the
#. * model, vendor or ID, e.g. 'LP2480zx Monitor'
#: ../common/xfce-randr.c:610 ../dialogs/color-settings/color-device.c:65
msgid "Monitor"
msgstr "ຈໍພາບ"

#: ../common/xfce-randr.c:613
msgid "Television"
msgstr "ໂທລະພາບ"

#: ../common/xfce-randr.c:617
msgid "Digital display"
msgstr "ຈໍສະແດງຜົນດິຈິຕອນ"

