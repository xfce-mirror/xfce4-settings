#: xfce4-settings-editor/xfce-settings-prop-dialog.c:368
msgid "Property names must start with a '/' character"
msgstr "ຊື່ຄຸນສົມບັດຕ້ອງເລີ່ມຕົ້ນດ້ວຍຕົວອັກສອນ '/'"

#: xfce4-settings-editor/xfce-settings-prop-dialog.c:379
msgid "The root element ('/') is not a valid property name"
msgstr "ຕົວປະກອບຮາກ ('/') ບໍ່ແມ່ນຊື່ຄຸນສົມບັດທີ່ຖືກຕ້ອງ"

#: xfce4-settings-editor/xfce-settings-prop-dialog.c:396
msgid ""
"Property names can only include the ASCII characters A-Z, a-z, 0-9, '_', "
"'-', ':', '.', ',', '[', ']', '{', '}', '<' and '>', as well as '/' as a "
"separator"
msgstr "ຊື່ຄຸນສົມບັດສາມາດມີສະເພາະຕົວອັກສອນ ASCII ເທົ່ານັ້ນ"

#: xfce4-settings-editor/xfce-settings-prop-dialog.c:410
msgid "Property names cannot have two or more consecutive '/' characters"
msgstr "ຊື່ຄຸນສົມບັດຕ້ອງບໍ່ມີຕົວອັກສອນ '/' ຕິດຕໍ່ກັນເກີນໜຶ່ງຕົວ"

#: xfce4-settings-editor/xfce-settings-prop-dialog.c:424
msgid "Property names cannot end with a '/' character"
msgstr "ຊື່ຄຸນສົມບັດຕ້ອງບໍ່ລົງທ້າຍດ້ວຍຕົວອັກສອນ '/'"

